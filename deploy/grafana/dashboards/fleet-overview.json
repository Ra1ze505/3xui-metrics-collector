{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "count(xui_up == 1)", "refId": "A" }],
      "title": "Panels Up",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(xui_node_online_clients{panel=~\"$panel\",node=~\"$node\"})", "refId": "A" }],
      "title": "Total Online Clients",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 3,
      "targets": [
        { "expr": "sum by (panel, node) (rate(xui_client_up_bytes_total{panel=~\"$panel\",node=~\"$node\"}[5m]) + rate(xui_client_down_bytes_total{panel=~\"$panel\",node=~\"$node\"}[5m]))", "legendFormat": "{{panel}}/{{node}}", "refId": "A" }
      ],
      "title": "Client Traffic Rate by Node",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Up" }, "properties": [{ "id": "mappings", "value": [{ "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }] }] },
          { "matcher": { "id": "byName", "options": "Heartbeat Age" }, "properties": [{ "id": "unit", "value": "s" }] }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "id": 4,
      "options": { "showHeader": true, "sortBy": [{ "desc": false, "displayName": "Node" }] },
      "targets": [{
        "expr": "xui_node_up{panel=~\"$panel\",node=~\"$node\"}",
        "format": "table",
        "instant": true,
        "refId": "A"
      }, {
        "expr": "xui_node_cpu_percent{panel=~\"$panel\",node=~\"$node\"}",
        "format": "table",
        "instant": true,
        "refId": "B"
      }, {
        "expr": "xui_node_mem_percent{panel=~\"$panel\",node=~\"$node\"}",
        "format": "table",
        "instant": true,
        "refId": "C"
      }, {
        "expr": "xui_node_online_clients{panel=~\"$panel\",node=~\"$node\"}",
        "format": "table",
        "instant": true,
        "refId": "D"
      }, {
        "expr": "xui_node_uptime_seconds{panel=~\"$panel\",node=~\"$node\"}",
        "format": "table",
        "instant": true,
        "refId": "E"
      }, {
        "expr": "time() - xui_node_last_heartbeat_seconds{panel=~\"$panel\",node=~\"$node\",role=\"node\"}",
        "format": "table",
        "instant": true,
        "refId": "F"
      }],
      "title": "Nodes Overview",
      "transformations": [
        { "id": "seriesToColumns", "options": { "byField": "node" } },
        { "id": "organize", "options": {
          "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true, "role": true },
          "renameByName": {
            "Value #A": "Up",
            "Value #B": "CPU %",
            "Value #C": "Mem %",
            "Value #D": "Online",
            "Value #E": "Uptime",
            "Value #F": "Heartbeat Age",
            "panel": "Panel"
          }
        }}
      ],
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["3x-ui", "fleet"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(xui_up, panel)",
        "includeAll": true,
        "multi": true,
        "name": "panel",
        "query": "label_values(xui_up, panel)",
        "refresh": 2,
        "type": "query"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(xui_node_up{panel=~\"$panel\"}, node)",
        "includeAll": true,
        "multi": true,
        "name": "node",
        "query": "label_values(xui_node_up{panel=~\"$panel\"}, node)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "3x-ui Fleet Overview",
  "uid": "xui-fleet-overview",
  "version": 1
}
